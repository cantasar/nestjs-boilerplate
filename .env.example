# Application
NODE_ENV=development
PORT=3000

# Database - DATABASE_URL or separate params (default: localhost:5432/app)
DATABASE_URL=postgres://user:password@localhost:5432/dbname
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_PASSWORD=password
# DATABASE_NAME=app

# JWT (required)
JWT_SECRET=change_me_in_production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Redis (default: redis://localhost:6379)
REDIS_URL=redis://localhost:6379
REDIS_TTL=180

# Mail - optional (required for forgot-password)
# ZEPTOMAIL_URL=https://api.zeptomail.com/
# ZEPTOMAIL_TOKEN=change_me
# MAIL_FROM_ADDRESS=no-reply@example.com
# MAIL_FROM_NAME=API

# Rate limit
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# CORS (comma-separated origin list, empty allows all origins)
# CORS_ORIGIN=https://app.example.com,https://admin.example.com
