# Application
NODE_ENV=development
PORT=3000
# OpenAPI — set SWAGGER_ENABLED=false to disable UI entirely
# SWAGGER_ENABLED=true
# Production: both required. Dev: optional (no Basic Auth if unset)
# SWAGGER_BASIC_AUTH_USER=admin
# SWAGGER_BASIC_AUTH_PASSWORD=change_me_strong_password

# Database - DATABASE_URL or separate params (default: localhost:5432/app)
DATABASE_URL=postgres://user:password@localhost:5432/dbname
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_PASSWORD=password
# DATABASE_NAME=app

# JWT (required)
JWT_SECRET=change_me_in_production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Redis (default: redis://localhost:6379)
REDIS_URL=redis://localhost:6379
REDIS_TTL=180

# Mail - optional (required for forgot-password)
# ZEPTOMAIL_URL=https://api.zeptomail.com/
# ZEPTOMAIL_TOKEN=change_me
# MAIL_FROM_ADDRESS=no-reply@example.com
# MAIL_FROM_NAME=API

# Rate limit
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# CORS (comma-separated origin list, empty allows all origins)
# CORS_ORIGIN=https://app.example.com,https://admin.example.com

# Storage (GCS) - optional, feature-flagged by GCS_BUCKET.
# When unset the storage service is dormant and the media-cleanup sweep no-ops.
# GCS_BUCKET=my-bucket
# GCP_PROJECT_ID=my-gcp-project       # required when GCS_BUCKET is set
# GCS_CREDENTIALS_JSON_BASE64=         # base64 service-account JSON; omit to use ADC
# GCS_PRESIGN_EXPIRES=900

# SMS - optional, feature-flagged by SMS_API_URL (generic code-prefixed gateway).
# SMS_API_URL=https://gateway.example.com/sms/send
# SMS_USER=change_me                   # required when SMS_API_URL is set
# SMS_PASS=change_me                   # required when SMS_API_URL is set
# SMS_SENDER_HEADER=MyApp
# SMS_SUCCESS_PREFIX=00
# SMS_OTP_TEMPLATE=Your code: {otp}
# Query-param name overrides (defaults: usercode/password/gsmno/message/msgheader)
# SMS_USER_PARAM=usercode
# SMS_PASS_PARAM=password
# SMS_TO_PARAM=gsmno
# SMS_MESSAGE_PARAM=message
# SMS_HEADER_PARAM=msgheader
