{
  "name": "nestjs-boilerplate",
  "version": "1.0.0",
  "private": false,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test",
    "prepare": "husky",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:pull": "drizzle-kit pull --config=drizzle.config.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "oxlint --fix src test",
    "lint:check": "oxlint src test && pnpm lint:no-double-cast && pnpm lint:no-prod-never && pnpm lint:no-untyped-promise && pnpm lint:no-multi-class-dto",
    "lint:no-double-cast": "! grep -rn 'as unknown as' src --include='*.ts' --exclude='*.spec.ts' 2>/dev/null || (echo '✗ Forbidden: as unknown as double-cast in production code. Use proper types or a single cast. Tests may use double-cast for mock typing.' && exit 1)",
    "lint:no-prod-never": "! grep -rn 'as never' src --include='*.ts' --exclude='*.spec.ts' 2>/dev/null || (echo '✗ Forbidden: as never cast in production code. Use literal union types instead.' && exit 1)",
    "lint:no-untyped-promise": "node scripts/check-untyped-promise.mjs",
    "lint:no-multi-class-dto": "for f in $(find src -name '*.dto.ts'); do [ \"$(grep -c 'export class' \"$f\")\" -gt 1 ] && { echo \"✗ Forbidden: more than one exported class in $f. One DTO per file (SoC).\"; exit 1; }; done; true",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "docs:generate": "node scripts/generate-api-docs.mjs"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.21.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@onesignal/node-onesignal": "^5.8.0",
    "apple-signin-auth": "^2.0.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.78.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "drizzle-orm": "^0.45.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zeptomail": "^7.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.15",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^15.5.2",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "diagnostics": {
            "ignoreCodes": [
              151002
            ]
          }
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,cjs}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "src/**/!(*.spec).ts": [
      "bash -c '! grep -l \"as unknown as\" \"$@\" || (echo \"✗ Forbidden as unknown as double-cast in staged production files\" && exit 1)' --",
      "bash -c '! grep -l \"as never\" \"$@\" || (echo \"✗ Forbidden as never cast in staged production files\" && exit 1)' --",
      "node scripts/check-untyped-promise.mjs",
      "bash -c 'for f in \"$@\"; do case \"$f\" in *.dto.ts) [ \"$(grep -c \"export class\" \"$f\")\" -gt 1 ] && { echo \"✗ Multiple exported classes in $f (one DTO per file)\"; exit 1; };; esac; done; true' --"
    ]
  }
}
